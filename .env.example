# =============================================================================
# Kalshi Investment Assistant — environment variables
# Copy this file to .env.local and fill in your own values.
# DO NOT commit .env.local or any real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Kalshi API — Demo (paper trading)
# -----------------------------------------------------------------------------
KALSHI_API_KEY_ID_DEMO=your_demo_key_id
# Either provide the PEM file path (local dev)...
KALSHI_API_PRIVATE_KEY_PATH_DEMO=./kalshi/private_key_demo.pem
# ...or provide the PEM contents inline with literal \n for newlines (e.g. Vercel)
KALSHI_PRIVATE_KEY_DEMO=

# -----------------------------------------------------------------------------
# Kalshi API — Production (optional, only needed for live trading)
# -----------------------------------------------------------------------------
KALSHI_API_KEY_ID=your_prod_key_id
KALSHI_API_PRIVATE_KEY_PATH=./kalshi/private_key.pem
KALSHI_PRIVATE_KEY=
KALSHI_API_BASE_URL=https://demo-api.kalshi.co/trade-api/v2

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -----------------------------------------------------------------------------
# Cron authentication (used by GitHub Actions to call the API routes)
# -----------------------------------------------------------------------------
CRON_SECRET=your_random_secret

# -----------------------------------------------------------------------------
# External data enrichment (optional)
# -----------------------------------------------------------------------------
ODDS_API_KEY=your_odds_api_key   # https://the-odds-api.com/ (500 req/month free)
FRED_API_KEY=your_fred_api_key   # https://fred.stlouisfed.org/ (free, 120 req/min)

# -----------------------------------------------------------------------------
# Email alerts (optional — Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=your_resend_key   # https://resend.com/ (100 emails/day free)
RESEND_FROM_EMAIL=alerts@yourdomain.com
ALERT_EMAIL=you@email.com
